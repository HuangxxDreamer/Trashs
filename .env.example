# Server
PORT=8080
LOG_LEVEL=info

# ROS2 Configuration
ROS_DOMAIN_ID=0
ROS_NAMESPACE=""
ROS_NODE_NAME=dog_stream_gateway

# Topics
TOPIC_CLOUD=/rtabmap/cloud_map
TOPIC_GRID=/rtabmap/grid_map

# WebRTC Configuration
WEBRTC_PORT_MIN=40000
WEBRTC_PORT_MAX=50000
BUFFER_THRESHOLD_KB=500

# Processing Configuration
VOXEL_SIZE=0.1
MAX_POINTS=8000
GRID_COMPRESSION_QUALITY=80
